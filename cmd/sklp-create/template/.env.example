# Skalpai observability — get these from app.skalpai.dev
SKALPAI_PROJECT_ID=
SKALPAI_API_KEY=
SKALPAI_ENDPOINT=http://localhost:4417

# Scaleway registry push (publish only)
SCW_SECRET_KEY=
SCW_ACCESS_KEY=

# Core
PORT=4100
DATABASE_URL=postgres://app:app@localhost:5432/app?sslmode=disable
NATS_URL=nats://localhost:4222

# Auth (web app owns better-auth; the Go core verifies the minted JWT).
# JWT_SECRET MUST be identical in the web app and the Go core.
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_URL=http://localhost:5273
JWT_SECRET=change-me-in-production
APP_NAME=app
# Where the web server proxies /api/core/* (the Go core). Defaults to :4100.
CORE_API_URL=http://localhost:4100
# Optional OAuth providers (omit to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional: cross-subdomain cookie + HTTPS-only cookies
# COOKIE_DOMAIN=.example.com
# Required to install @digstack packages from GitHub Packages (private).
# @lalternative packages are public on npmjs and need no token.
GITHUB_TOKEN=
