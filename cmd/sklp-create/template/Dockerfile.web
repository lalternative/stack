# web image — SSR server (TanStack Start + Nitro)
# Pin pnpm explicitly (never @latest in Dockerfile.web — see memory).
FROM node:22-bookworm AS build
RUN corepack enable && corepack prepare pnpm@10.27.0 --activate
WORKDIR /src
ENV CI=true
# Workspace manifests first (better layer caching).
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json ./apps/web/package.json
COPY lib/front/package.json ./lib/front/package.json
RUN pnpm install --frozen-lockfile
# Then the sources: the web app and the shared front lib it imports.
COPY apps/web ./apps/web
COPY lib/front ./lib/front
RUN pnpm --filter @app/web build
# Prune to production deps for the runtime image.
RUN pnpm deploy --filter @app/web --prod --legacy /prod

FROM node:22-bookworm-slim
ENV NODE_ENV=production
WORKDIR /app
COPY --from=build /prod/node_modules ./node_modules
COPY --from=build /src/apps/web/.output ./.output
RUN groupadd -g 10001 app && useradd -u 10001 -g app -M -s /usr/sbin/nologin app
USER 10001:10001
ENV PORT=5273
EXPOSE 5273
CMD ["node", ".output/server/index.mjs"]
