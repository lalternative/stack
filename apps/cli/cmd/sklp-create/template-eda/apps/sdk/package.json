{
  "name": "@app/sdk",
  "version": "0.1.0",
  "description": "Typed TypeScript client for the Core API, generated from OpenAPI.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "generate": "orval --config orval.config.ts",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.7"
  },
  "devDependencies": {
    "orval": "^7.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3"
  }
}
